# --- Neon Postgres ---
# One connection string from the Neon Console → Connect (used by both the app
# and the Prisma CLI). The pooled string (host contains "-pooler") works fine.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Server config
PORT=3001
FRONTEND_URL=http://localhost:3000
